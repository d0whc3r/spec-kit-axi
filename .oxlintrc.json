{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "promise"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true,
    "node": true,
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    ".astro/**",
    ".specify/**",
    ".claude/**",
    ".agents/**",
    ".vscode/**",
    ".github/agents/**",
    "specs/**",
    "web/public/examples/**",
    "web-review/*.mjs"
  ],
  "rules": {}
}

{
  "name": "spec-kit-axi",
  "version": "0.0.0",
  "private": true,
  "description": "TODO: describe the axi Spec Kit extension.",
  "keywords": [
    "axi",
    "spec-kit",
    "spec-kit-extension"
  ],
  "homepage": "https://d0whc3r.github.io/spec-kit-axi/",
  "bugs": {
    "url": "https://github.com/d0whc3r/spec-kit-axi/issues"
  },
  "license": "MIT",
  "author": "d0whc3r",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d0whc3r/spec-kit-axi.git"
  },
  "scripts": {
    "oxfmt": "oxfmt --no-error-on-unmatched-pattern",
    "lint": "pnpm run oxfmt --check",
    "lint:content": "node .github/scripts/lint-content.mjs",
    "format": "pnpm run oxfmt --write",
    "validate": "node .github/scripts/validate-manifest.mjs",
    "sync": "node .github/scripts/sync-metadata.mjs",
    "sync:check": "node .github/scripts/sync-metadata.mjs --check",
    "build": "node .github/scripts/build-zip.mjs",
    "catalog:issue": "node .github/scripts/submit-catalog-update.mjs",
    "examples:sync": "rm -rf web/public/examples && cp -r examples web/public/examples",
    "web:dev": "pnpm --filter @spec-kit-axi/web dev",
    "web:build": "pnpm examples:sync && pnpm --filter @spec-kit-axi/web build",
    "web:preview": "pnpm --filter @spec-kit-axi/web preview",
    "check": "pnpm run validate && pnpm run sync:check && pnpm run lint && pnpm run lint:content",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "semantic-release": "25.0.5",
    "zx": "8.8.5"
  },
  "lint-staged": {
    "*": "pnpm run format"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0"
}

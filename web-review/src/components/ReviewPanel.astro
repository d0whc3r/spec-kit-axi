---
import Button, { buttonVariants } from "@/components/ui/button.astro";
import Card from "@/components/ui/card.astro";
import Badge from "@/components/ui/badge.astro";

// Review notes + agent chat. Note cards, agent bubbles, and the typing
// indicator are stamped at runtime from the <template>s below so they stay
// real shadcn markup.
---

<aside
  class="flex min-h-0 flex-col border-t border-border bg-card lg:border-l lg:border-t-0"
  aria-label="Review notes"
>
  <div class="flex h-12 shrink-0 items-center justify-between gap-2 border-b border-border px-4">
    <div class="flex items-center gap-2">
      <span class="text-sm font-semibold">Notes</span>
      <Badge id="qcount" variant="secondary" class="min-w-6 justify-center tabular-nums">0</Badge>
    </div>
    <span
      id="status"
      class="inline-flex items-center gap-1.5 rounded-full border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors"
    >
      <span data-dot class="size-1.5 rounded-full bg-current"></span>
      <span data-text>agent not connected</span>
    </span>
  </div>

  <div id="thread" class="flex min-h-0 flex-1 flex-col gap-2 overflow-y-auto p-3 max-lg:max-h-[60vh]">
    <div id="intro" class="rounded-lg border border-dashed border-border p-4 text-sm">
      <p class="mb-2 font-semibold">Review this feature</p>
      <ol class="m-0 list-decimal space-y-1.5 pl-4 text-muted-foreground">
        <li>Select any text in the document to attach a note to it.</li>
        <li>Or type a comment below to talk about the whole feature.</li>
        <li>Notes stack up here. Send them to the agent when you are ready.</li>
      </ol>
      <button id="empty-help" type="button" class={buttonVariants({ variant: "link", size: "sm" }) + " mt-1 h-auto p-0"}>
        How does this work?
      </button>
    </div>
    <ul id="queue" class="m-0 flex list-none flex-col gap-2 p-0"></ul>
    <div id="messages" class="flex flex-col gap-2" aria-label="Agent replies"></div>
  </div>

  <div class="shrink-0 border-t border-border p-3">
    <p
      id="busy-hint"
      hidden
      role="status"
      aria-live="polite"
      class="mb-2 flex items-center gap-2 rounded-md border border-primary/30 bg-primary/10 px-3 py-2 text-xs font-medium text-primary"
    >
      <span class="size-1.5 shrink-0 animate-pulse rounded-full bg-current" aria-hidden="true"></span>
      <span data-text></span>
    </p>
    <form id="composer" autocomplete="off">
      <div class="flex items-end gap-2 rounded-lg border border-input bg-background py-1.5 pl-3 pr-1.5 shadow-sm transition focus-within:ring-2 focus-within:ring-ring focus-within:ring-offset-2 focus-within:ring-offset-background">
        <textarea
          id="composer-input"
          class="max-h-64 min-w-0 flex-1 resize-none bg-transparent py-1 text-sm leading-relaxed field-sizing-content placeholder:text-muted-foreground focus:outline-none"
          rows="1"
          placeholder="Comment on the feature. Enter to stack a note, Shift+Enter for a newline."
        ></textarea>
        <Button id="send" type="submit" size="icon" class="size-8 shrink-0 rounded-full" aria-label="Send notes to the agent" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4Z"></path>
            <path d="M22 2 11 13"></path>
          </svg>
        </Button>
      </div>
    </form>
  </div>
</aside>

<template id="tpl-note-card">
  <li>
    <Card data-note-card class="relative p-3 shadow-sm">
      <button
        type="button"
        data-remove
        aria-label="Remove note"
        class={buttonVariants({ variant: "ghost" }) + " absolute right-2 top-2 size-6 p-0 text-muted-foreground"}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
      <div class="flex items-center gap-2 pr-6">
        <Badge data-kind variant="secondary" class="shrink-0">note</Badge>
        <span data-meta class="truncate text-xs text-muted-foreground"></span>
      </div>
      <blockquote data-quote class="mt-2 border-l-2 border-primary/50 pl-2 text-xs italic text-muted-foreground"></blockquote>
      <textarea
        data-note
        rows="2"
        placeholder="note…"
        class="mt-2 max-h-64 w-full resize-y rounded-md border border-input bg-background px-2.5 py-1.5 text-sm field-sizing-content placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      ></textarea>
    </Card>
  </li>
</template>

<template id="tpl-message">
  <div class="max-w-[90%] self-start rounded-lg rounded-tl-sm bg-muted px-3 py-2 text-sm leading-relaxed">
    <span class="mb-1 block text-[0.62rem] font-bold uppercase tracking-wide text-primary">agent</span>
    <span data-text class="whitespace-pre-wrap"></span>
  </div>
</template>

<template id="tpl-typing">
  <div class="flex w-fit items-center gap-1 self-start rounded-lg rounded-tl-sm bg-muted px-3 py-3" aria-label="Agent is working">
    <span class="size-1.5 animate-bounce rounded-full bg-muted-foreground [animation-delay:0ms]"></span>
    <span class="size-1.5 animate-bounce rounded-full bg-muted-foreground [animation-delay:150ms]"></span>
    <span class="size-1.5 animate-bounce rounded-full bg-muted-foreground [animation-delay:300ms]"></span>
  </div>
</template>

---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/lib/utils";

type Props = HTMLAttributes<"div">;
const { class: className, ...rest } = Astro.props;
---

<div
  role="menu"
  data-dropdown-content
  data-state="closed"
  hidden
  class={cn(
    "absolute right-0 z-50 mt-2 min-w-[8rem] overflow-hidden rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95",
    className,
  )}
  {...rest}
>
  <slot />
</div>

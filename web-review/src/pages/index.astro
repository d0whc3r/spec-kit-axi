---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import Sidebar from "@/components/Sidebar.astro";
import Document from "@/components/Document.astro";
import ReviewPanel from "@/components/ReviewPanel.astro";
import HelpDialog from "@/components/HelpDialog.astro";

// The review shell, composed of shadcn components. Each zone owns its markup,
// its runtime <template> prototypes, and its own styles; the client script
// (axi.ts) stamps the dynamic widgets from those templates at runtime.
---

<Layout>
  <div class="flex flex-col bg-background text-foreground lg:h-screen lg:overflow-hidden">
    <Topbar />

    <!-- Body: three zones on desktop, stacked on small screens. The sidebar
         column width follows --sidebar-w (see Sidebar.astro). -->
    <div id="shell" class="flex flex-1 flex-col lg:grid lg:min-h-0">
      <Sidebar />
      <Document />
      <ReviewPanel />
    </div>
  </div>

  <HelpDialog />

  <script>
    import "../scripts/axi.ts";
  </script>
</Layout>
